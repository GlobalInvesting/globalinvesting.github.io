# ─────────────────────────────────────────────────────────────────────────────
# Cabeceras de seguridad HTTP — globalinvesting.github.io
# Compatible con: Cloudflare Pages, Netlify
# Última actualización: 2026-03-12
# ─────────────────────────────────────────────────────────────────────────────

/*
  # Strict-Transport-Security: HSTS con preload (máx. 1 año)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Previene clickjacking — solo permite iframes desde el mismo origen
  X-Frame-Options: SAMEORIGIN

  # Previene MIME-sniffing attacks
  X-Content-Type-Options: nosniff

  # Limita referrer a origen estricto en cross-origin
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy — deshabilita APIs no usadas
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Content-Security-Policy
  # NOTA: Se usa 'unsafe-inline' porque React y Chart.js inyectan estilos inline.
  # En una refactorización futura, separar JS en módulos y eliminar unsafe-inline.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net unpkg.com pagead2.googlesyndication.com partner.googleadservices.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src fonts.gstatic.com; img-src 'self' data: https: flagcdn.com; connect-src 'self' https://globalinvesting.github.io https://api.frankfurter.app https://api.worldbank.org https://api.stlouisfed.org https://api.exchangerate-api.com https://open.er-api.com https://sdmx.oecd.org; frame-ancestors 'self'; upgrade-insecure-requests

# Datos JSON estáticos — cache de 1 hora
/strength-scores/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=300

/economic-data/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/cot-data/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/rates/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/ai-analysis/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=300

/extended-data/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

# Assets estáticos — cache largo
/*.png
  Cache-Control: public, max-age=2592000

/*.ico
  Cache-Control: public, max-age=2592000
